   "cell_type": "code",
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "def process_sales_optimized(path, chunksize=100_000):\n",
    "    
    "\n",
    "    chunks = []  # Lista do przechowywania przetworzonych chunków\n",
    "\n",
    "    for chunk in pd.read_csv(path, chunksize=chunksize):\n",
    "       
    "        for col in chunk.select_dtypes(include=\"object\"):\n",
    "            chunk[col] = chunk[col].astype(\"category\")  # tekst → category\n",
    "\n",
    "       
    "        for col in chunk.select_dtypes(include=\"int\"):\n",
    "            chunk[col] = pd.to_numeric(chunk[col], downcast=\"integer\")\n",
    "        for col in chunk.select_dtypes(include=\"float\"):\n",
    "            chunk[col] = pd.to_numeric(chunk[col], downcast=\"float\")\n",
    "\n",
    "       
    "        chunk[\"flag\"] = np.where(\n",
    "            (chunk[\"amount\"] > 1000) & (chunk[\"country\"] == \"PL\"),\n",
    "            1,\n",
    "            0\n",
    "        )\n",
    "\n",
    "        chunks.append(chunk)\n",
    "\n",
    "    
    "    df_final = pd.concat(chunks, ignore_index=True)\n",
    "    return df_final\n"
   ],
